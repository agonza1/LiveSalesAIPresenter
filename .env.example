# ConversationAgentEvals local environment

# Shared ports / service URLs
PORT=3012
API_PORT=8025
PIPECAT_PORT=8110
API_BASE_URL=http://localhost:8025
PIPECAT_SERVICE_URL=http://localhost:8110
NEXT_PUBLIC_API_BASE_URL=http://localhost:8025
NEXT_PUBLIC_PIPECAT_SERVICE_URL=http://localhost:8110
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3012
PLAYWRIGHT_REUSE_EXISTING_SERVER=1

# Models / providers
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_RESPONSES_MODEL=gpt-4.1-mini

# Runtime tuning
REALTIME_REQUEST_TIMEOUT_MS=5000
APP_ENV=development
# Set PRODUCTION=true to hide non-live testing controls such as text Q&A and simulated voice.
PRODUCTION=false
